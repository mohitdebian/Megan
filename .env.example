# ─── LLM / AI Configuration ───
# By default, Megan connects to a local proxy (like litellm) to abstract the AI API.
# You can use Anthropic (Claude 3 Opus/Sonnet), or any provider via the proxy.
CLAUDE_BASE_URL=http://localhost:8082
CLAUDE_AUTH_TOKEN=your_auth_token_here
CLAUDE_MODEL=anthropic/your_model_name_here

# ─── TTS Configuration (ElevenLabs or NVIDIA) ───
# ElevenLabs is recommended for the best voice experience.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# NVIDIA Magpie Fallback
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_TTS_URL=https://integrate.api.nvidia.com/v1/audio/speech
NVIDIA_TTS_VOICE=magpie-multilingual

# ─── STT Configuration ───
STT_MODEL=base
STT_DEVICE=cuda   # Use 'cpu' if you do not have an NVIDIA GPU
AUDIO_SAMPLE_RATE=16000

# ─── Telegram Remote Control ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── WhatsApp Bridge ───
WHATSAPP_BRIDGE_URL=http://localhost:3001

# ─── Memory ───
SQLITE_PATH=./data/memory.db
CHROMA_PATH=./data/chroma

# ─── Server ───
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ─── Safety ───
REQUIRE_CONFIRMATION=true
ALLOWED_DIRS=/home
COMMAND_TIMEOUT=30
